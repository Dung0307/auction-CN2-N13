<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: #12121A;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="auction.client.controller.MainViewController">

    <top>
        <fx:include source="NavBar.fxml"/>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: #12121A; -fx-border-color: transparent;">
            <content>
                <FlowPane alignment="TOP_CENTER" hgap="20.0" vgap="20.0">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="30.0"/>
                    </padding>
                    <children>

                        <HBox prefHeight="170.0" prefWidth="350.0" spacing="15.0"
                              style="-fx-background-color: rgba(30, 30, 40, 0.8); -fx-border-color: #D8A95C; -fx-border-width: 0 0 0 4; -fx-background-radius: 4; -fx-padding: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 10, 0, 0, 5);">
                            <StackPane prefHeight="140.0" prefWidth="110.0"
                                       style="-fx-background-color: #0B0B10; -fx-background-radius: 4; -fx-border-color: #4A4A5A; -fx-border-radius: 4;">
                                <children>
                                    <ImageView fitHeight="130.0" fitWidth="100.0" pickOnBounds="true"
                                               preserveRatio="true">
                                        <image>
                                            <Image url="https://images.unsplash.com/photo-1523170335258-f5ed11844a49?auto=format&amp;fit=crop&amp;w=400&amp;q=80"/>
                                        </image>
                                    </ImageView>
                                </children>
                            </StackPane>
                            <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                <Label text="Đồng hồ Rolex GMT-Master II" wrapText="true"
                                       style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #E5E5E5;"/>
                                <Label text="Đồng hồ cao cấp" style="-fx-text-fill: #A0A0B0; -fx-font-size: 11px;"/>
                                <Label text="Tình trạng: Mới nguyên, #081/088"
                                       style="-fx-text-fill: #A0A0B0; -fx-font-size: 11px;"/>

                                <Region VBox.vgrow="ALWAYS"/>

                                <Label text="1 lượt đăng bán từ" style="-fx-font-size: 12px; -fx-text-fill: #777788;"/>
                                <Label text="500.000.000 VNĐ"
                                       style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-text-fill: #D8A95C; -fx-effect: dropshadow(one-pass-box, rgba(216,169,92,0.4), 5, 0, 0, 0);"/>
                                <HBox alignment="CENTER_LEFT" spacing="5.0">
                                    <Label text="Giá thị trường:" style="-fx-text-fill: #777788; -fx-font-size: 11px;"/>
                                    <Label text="550.000.000 VNĐ"
                                           style="-fx-text-fill: #00E5FF; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                                </HBox>

                                <Button onAction="#handleBid" userData="Rolex GMT-Master II Ice" text="⚡ ĐẤU GIÁ NGAY"
                                        maxWidth="Infinity"
                                        style="-fx-background-color: linear-gradient(to right, #D8A95C, #F4D28A); -fx-text-fill: #12121A; -fx-border-radius: 4; -fx-background-radius: 4; -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand;">
                                    <VBox.margin>
                                        <Insets top="8.0"/>
                                    </VBox.margin>
                                </Button>
                            </VBox>
                        </HBox>

                        <HBox prefHeight="170.0" prefWidth="350.0" spacing="15.0"
                              style="-fx-background-color: rgba(30, 30, 40, 0.8); -fx-border-color: #D8A95C; -fx-border-width: 0 0 0 4; -fx-background-radius: 4; -fx-padding: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 10, 0, 0, 5);">
                            <StackPane prefHeight="140.0" prefWidth="110.0"
                                       style="-fx-background-color: #0B0B10; -fx-background-radius: 4; -fx-border-color: #4A4A5A; -fx-border-radius: 4;">
                                <children>
                                    <ImageView fitHeight="130.0" fitWidth="100.0" pickOnBounds="true"
                                               preserveRatio="true">
                                        <image>
                                            <Image url="https://tse1.mm.bing.net/th/id/OIP.oSBsXXbXHRlAFvjQqPzEtQHaKl?rs=1&amp;pid=ImgDetMain&amp;o=7a&amp;rm=3"/>
                                        </image>
                                    </ImageView>
                                </children>
                            </StackPane>
                            <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                <Label text="Blue-Eyes White Dragon" wrapText="true"
                                       style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #E5E5E5;"/>
                                <Label text="Bộ sưu tập huyền thoại"
                                       style="-fx-text-fill: #A0A0B0; -fx-font-size: 11px;"/>
                                <Label text="Siêu hiếm, #001/100" style="-fx-text-fill: #A0A0B0; -fx-font-size: 11px;"/>

                                <Region VBox.vgrow="ALWAYS"/>

                                <Label text="2 lượt đăng bán từ" style="-fx-font-size: 12px; -fx-text-fill: #777788;"/>
                                <Label text="120.000.000 VNĐ"
                                       style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-text-fill: #D8A95C; -fx-effect: dropshadow(one-pass-box, rgba(216,169,92,0.4), 5, 0, 0, 0);"/>
                                <HBox alignment="CENTER_LEFT" spacing="5.0">
                                    <Label text="Giá thị trường:" style="-fx-text-fill: #777788; -fx-font-size: 11px;"/>
                                    <Label text="125.000.000 VNĐ"
                                           style="-fx-text-fill: #00E5FF; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                                </HBox>
                                <Button onAction="#handleBid" userData="Blue-Eyes White Dragon" text="⚡ ĐẤU GIÁ NGAY"
                                        maxWidth="Infinity"
                                        style="-fx-background-color: linear-gradient(to right, #D8A95C, #F4D28A); -fx-text-fill: #12121A; -fx-border-radius: 4; -fx-background-radius: 4; -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand;">
                                    <VBox.margin>
                                        <Insets top="8.0"/>
                                    </VBox.margin>
                                </Button>
                            </VBox>
                        </HBox>

                        <HBox prefHeight="170.0" prefWidth="350.0" spacing="15.0"
                              style="-fx-background-color: rgba(30, 30, 40, 0.8); -fx-border-color: #D8A95C; -fx-border-width: 0 0 0 4; -fx-background-radius: 4; -fx-padding: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 10, 0, 0, 5);">
                            <StackPane prefHeight="140.0" prefWidth="110.0"
                                       style="-fx-background-color: #0B0B10; -fx-background-radius: 4; -fx-border-color: #4A4A5A; -fx-border-radius: 4;">
                                <children>
                                    <ImageView fitHeight="130.0" fitWidth="100.0" pickOnBounds="true"
                                               preserveRatio="true">
                                        <image>
                                            <Image url="https://image.stern.de/33757640/t/p_/v3/w1440/r1.7778/-/rolls-royce-la-rose-noir-droptail-5.jpg"/>
                                        </image>
                                    </ImageView>
                                </children>
                            </StackPane>
                            <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                <Label text="Rolls-Royce Droptail" wrapText="true"
                                       style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #E5E5E5;"/>
                                <Label text="Siêu xe &amp; Phương tiện"
                                       style="-fx-text-fill: #A0A0B0; -fx-font-size: 11px;"/>
                                <Label text="Phiên bản độc quyền" style="-fx-text-fill: #A0A0B0; -fx-font-size: 11px;"/>

                                <Region VBox.vgrow="ALWAYS"/>

                                <Label text="1 lượt đăng bán từ" style="-fx-font-size: 12px; -fx-text-fill: #777788;"/>
                                <Label text="380 Tỷ VNĐ"
                                       style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-text-fill: #D8A95C; -fx-effect: dropshadow(one-pass-box, rgba(216,169,92,0.4), 5, 0, 0, 0);"/>
                                <HBox alignment="CENTER_LEFT" spacing="5.0">
                                    <Label text="Giá thị trường:" style="-fx-text-fill: #777788; -fx-font-size: 11px;"/>
                                    <Label text="700 Tỷ VNĐ"
                                           style="-fx-text-fill: #00E5FF; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                                </HBox>

                                <Button onAction="#handleBid" userData="Rolls-Royce Droptail" text="⚡ ĐẤU GIÁ NGAY"
                                        maxWidth="Infinity"
                                        style="-fx-background-color: linear-gradient(to right, #D8A95C, #F4D28A); -fx-text-fill: #12121A; -fx-border-radius: 4; -fx-background-radius: 4; -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand;">
                                    <VBox.margin>
                                        <Insets top="8.0"/>
                                    </VBox.margin>
                                </Button>
                            </VBox>
                        </HBox>

                    </children>
                </FlowPane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>