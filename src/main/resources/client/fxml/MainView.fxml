<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: #f8f9fa;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="auction.client.controller.MainController">

    <top>
        <fx:include source="NavBar.fxml"/>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <FlowPane alignment="TOP_CENTER" hgap="15.0" vgap="15.0">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="20.0"/>
                    </padding>
                    <children>

                        <HBox prefHeight="170.0" prefWidth="340.0" spacing="15.0"
                              style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12; -fx-cursor: hand;">
                            <StackPane prefHeight="145.0" prefWidth="110.0"
                                       style="-fx-background-color: #f8f9fa; -fx-background-radius: 4;">
                                <children>
                                    <ImageView fitHeight="130.0" fitWidth="100.0" pickOnBounds="true"
                                               preserveRatio="true">
                                        <image>
                                            <Image url="https://images.unsplash.com/photo-1523170335258-f5ed11844a49?auto=format&amp;fit=crop&amp;w=400&amp;q=80"/>
                                        </image>
                                    </ImageView>
                                </children>
                            </StackPane>
                            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                <Label text="Đồng hồ Rolex GMT-Master II" wrapText="true"
                                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #111;"/>
                                <Label text="Đồng hồ cao cấp" style="-fx-text-fill: #777; -fx-font-size: 11px;"/>
                                <Label text="Tình trạng: Mới nguyên, #081/088"
                                       style="-fx-text-fill: #777; -fx-font-size: 11px;"/>

                                <Region VBox.vgrow="ALWAYS"/>

                                <Label text="1 lượt đăng bán từ" style="-fx-font-size: 12px; -fx-text-fill: #333;"/>
                                <Label text="500.000.000 VNĐ"
                                       style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-text-fill: #000;"/>
                                <HBox alignment="CENTER_LEFT" spacing="5.0">
                                    <Label text="Giá thị trường:" style="-fx-text-fill: #777; -fx-font-size: 11px;"/>
                                    <Label text="550.000.000 VNĐ"
                                           style="-fx-text-fill: #27ae60; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                                </HBox>

                                <Button onAction="#handleBid" userData="Rolex GMT-Master II Ice" text="Đấu giá ngay"
                                        maxWidth="Infinity"
                                        style="-fx-background-color: #3f51b5; -fx-text-fill: white; -fx-border-radius: 4; -fx-font-size: 12px; -fx-font-weight: bold;">
                                    <VBox.margin>
                                        <Insets top="5.0"/>
                                    </VBox.margin>
                                </Button>
                            </VBox>
                        </HBox>

                        <HBox prefHeight="170.0" prefWidth="340.0" spacing="15.0"
                              style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12; -fx-cursor: hand;">
                            <StackPane prefHeight="145.0" prefWidth="110.0"
                                       style="-fx-background-color: #f8f9fa; -fx-background-radius: 4;">
                                <children>
                                    <ImageView fitHeight="130.0" fitWidth="100.0" pickOnBounds="true"
                                               preserveRatio="true">
                                        <image>
                                            <Image url="https://tse1.mm.bing.net/th/id/OIP.oSBsXXbXHRlAFvjQqPzEtQHaKl?rs=1&amp;pid=ImgDetMain&amp;o=7a&amp;rm=3"/>
                                        </image>
                                    </ImageView>
                                </children>
                            </StackPane>
                            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                <Label text="Thẻ bài Blue-Eyes White Dragon" wrapText="true"
                                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #111;"/>
                                <Label text="Bộ sưu tập huyền thoại" style="-fx-text-fill: #777; -fx-font-size: 11px;"/>
                                <Label text="Siêu hiếm, #001/100" style="-fx-text-fill: #777; -fx-font-size: 11px;"/>

                                <Region VBox.vgrow="ALWAYS"/>

                                <Label text="2 lượt đăng bán từ" style="-fx-font-size: 12px; -fx-text-fill: #333;"/>
                                <Label text="120.000.000 VNĐ"
                                       style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-text-fill: #000;"/>
                                <HBox alignment="CENTER_LEFT" spacing="5.0">
                                    <Label text="Giá thị trường:" style="-fx-text-fill: #777; -fx-font-size: 11px;"/>
                                    <Label text="125.000.000 VNĐ"
                                           style="-fx-text-fill: #27ae60; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                                </HBox>
                                <Button onAction="#handleBid" userData="Blue-Eyes White Dragon" text="Đấu giá ngay"
                                        maxWidth="Infinity"
                                        style="-fx-background-color: #3f51b5; -fx-text-fill: white; -fx-border-radius: 4; -fx-font-size: 12px; -fx-font-weight: bold;">
                                    <VBox.margin>
                                        <Insets top="5.0"/>
                                    </VBox.margin>
                                </Button>
                            </VBox>
                        </HBox>

                        <HBox prefHeight="170.0" prefWidth="340.0" spacing="15.0"
                              style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12; -fx-cursor: hand;">
                            <StackPane prefHeight="145.0" prefWidth="110.0"
                                       style="-fx-background-color: #f8f9fa; -fx-background-radius: 4;">
                                <children>
                                    <ImageView fitHeight="130.0" fitWidth="100.0" pickOnBounds="true"
                                               preserveRatio="true">
                                        <image>
                                            <Image url="https://image.stern.de/33757640/t/p_/v3/w1440/r1.7778/-/rolls-royce-la-rose-noir-droptail-5.jpg"/>
                                        </image>
                                    </ImageView>
                                </children>
                            </StackPane>
                            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                <Label text="Rolls-Royce Droptail" wrapText="true"
                                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #111;"/>
                                <Label text="Siêu xe &amp; Phương tiện"
                                       style="-fx-text-fill: #777; -fx-font-size: 11px;"/>
                                <Label text="Phiên bản độc quyền" style="-fx-text-fill: #777; -fx-font-size: 11px;"/>

                                <Region VBox.vgrow="ALWAYS"/>

                                <Label text="1 lượt đăng bán từ" style="-fx-font-size: 12px; -fx-text-fill: #333;"/>
                                <Label text="380.000.000.000 VNĐ"
                                       style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #000;"/>
                                <HBox alignment="CENTER_LEFT" spacing="5.0">
                                    <Label text="Giá thị trường:" style="-fx-text-fill: #777; -fx-font-size: 11px;"/>
                                    <Label text="700.000.000.000 VNĐ"
                                           style="-fx-text-fill: #27ae60; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                                </HBox>

                                <Button onAction="#handleBid" userData="Rolls-Royce Droptail" text="Đấu giá ngay"
                                        maxWidth="Infinity"
                                        style="-fx-background-color: #3f51b5; -fx-text-fill: white; -fx-border-radius: 4; -fx-font-size: 12px; -fx-font-weight: bold;">
                                    <VBox.margin>
                                        <Insets top="5.0"/>
                                    </VBox.margin>
                                </Button>
                            </VBox>
                        </HBox>

                    </children>
                </FlowPane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>