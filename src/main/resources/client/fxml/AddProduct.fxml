<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="850.0" prefWidth="1200.0" styleClass="main-background"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="auction.client.controller.AddProductController">

    <top>
        <fx:include source="NavBar.fxml"/>
    </top>

    <center>
        <HBox alignment="CENTER" spacing="40.0" style="-fx-padding: 40;">

            <VBox spacing="15.0" alignment="TOP_CENTER" prefWidth="400.0" styleClass="image-panel">

                <Label text="HÌNH ẢNH HOLOGRAM" styleClass="hologram-title"/>

                <VBox alignment="CENTER" styleClass="image-frame">
                    <ImageView fx:id="imagePreview" fitHeight="340.0" fitWidth="340.0" pickOnBounds="true"
                               preserveRatio="true"/>
                </VBox>

                <VBox spacing="8.0" style="-fx-padding: 10 0 0 0;">
                    <Label text="Đường dẫn dữ liệu ảnh (URL) *" style="-fx-font-weight: bold;" styleClass="text-muted"/>
                    <TextField fx:id="imageUrlField" promptText="Dán link ảnh vào đây..." prefHeight="45.0"
                               styleClass="dark-input-field"/>
                </VBox>

            </VBox>

            <VBox spacing="20.0" prefWidth="600.0" styleClass="form-panel">

                <VBox spacing="5.0">
                    <Label text="ĐĂNG SẢN PHẨM" styleClass="form-title"/>
                    <Label text="Nhập dữ liệu sản phẩm." style="-fx-font-size: 13px;" styleClass="text-muted"/>
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Tên sản phẩm" styleClass="text-bright"/>
                    <TextField fx:id="nameField" promptText="Nhập tên vật phẩm..." prefHeight="45.0"
                               styleClass="dark-input-field"/>
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Loại sản phẩm *" styleClass="text-bright"/>
                    <ComboBox fx:id="categoryBox" promptText="-- Chọn danh mục --" prefHeight="45.0" maxWidth="Infinity"
                              styleClass="dark-combo-box"/>
                </VBox>
                <HBox spacing="20.0">
                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <Label text="Giá khởi điểm (VNĐ)" styleClass="text-bright"/>
                        <TextField fx:id="priceField" promptText="VD: 50000" prefHeight="45.0"
                                   styleClass="dark-input-field"/>
                    </VBox>
                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <Label text="Bước nhảy giá tối thiểu *" styleClass="text-bright"/>
                        <TextField fx:id="stepField" promptText="VD: 1000" prefHeight="45.0"
                                   styleClass="dark-input-field"/>
                    </VBox>
                </HBox>

                <VBox spacing="8.0">
                    <Label text="Chi tiết dữ liệu (Mô tả) *" styleClass="text-bright"/>
                    <TextArea fx:id="descriptionArea" promptText="Nhập thông số kỹ thuật, nguồn gốc..."
                              prefHeight="160.0" wrapText="true" styleClass="dark-input-field"/>
                </VBox>

                <HBox spacing="15.0" alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0;">
                    <Button text="HỦY BỎ" onAction="#handleCancel" prefHeight="45.0" prefWidth="120.0"
                            styleClass="btn-cancel"/>
                    <Button text="🚀 ĐỒNG BỘ (ĐĂNG BÁN)" onAction="#handleSaveProduct" prefHeight="45.0"
                            prefWidth="220.0" styleClass="btn-submit"/>
                </HBox>

            </VBox>
        </HBox>
    </center>
</BorderPane>