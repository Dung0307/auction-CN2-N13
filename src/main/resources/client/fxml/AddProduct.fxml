<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="850.0" prefWidth="1200.0" style="-fx-background-color: #12121A;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="auction.client.controller.AddProductController">

    <top>
        <fx:include source="NavBar.fxml"/>
    </top>

    <center>
        <HBox alignment="CENTER" spacing="40.0" style="-fx-padding: 40;">
            <VBox spacing="15.0" alignment="TOP_CENTER" prefWidth="400.0"
                  style="-fx-background-color: rgba(26, 26, 36, 0.8); -fx-padding: 30; -fx-border-color: #4A4A5A; -fx-border-width: 1; -fx-background-radius: 8; -fx-border-radius: 8;">

                <Label text="HÌNH ẢNH HOLOGRAM"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #D8A95C; -fx-letter-spacing: 2px;"/>

                <VBox alignment="CENTER"
                      style="-fx-background-color: #0B0B10; -fx-border-color: #D8A95C; -fx-border-width: 2; -fx-min-height: 350; -fx-min-width: 350;">
                    <ImageView fx:id="imagePreview" fitHeight="340.0" fitWidth="340.0" pickOnBounds="true"
                               preserveRatio="true"/>
                </VBox>

                <VBox spacing="8.0" style="-fx-padding: 10 0 0 0;">
                    <Label text="Đường dẫn dữ liệu ảnh (URL) *" style="-fx-text-fill: #A0A0B0; -fx-font-weight: bold;"/>
                    <TextField fx:id="imageUrlField" promptText="Dán link ảnh vào đây..." prefHeight="45.0"
                               style="-fx-font-size: 14px; -fx-background-color: #242430; -fx-text-fill: white; -fx-border-color: #4A4A5A; -fx-background-radius: 4; -fx-border-radius: 4;"/>
                </VBox>
            </VBox>

            <VBox spacing="20.0" prefWidth="600.0"
                  style="-fx-background-color: rgba(26, 26, 36, 0.8); -fx-padding: 40; -fx-border-color: #D8A95C; -fx-border-width: 1 1 1 4; -fx-background-radius: 4; -fx-border-radius: 4; -fx-effect: dropshadow(three-pass-box, rgba(216,169,92,0.2), 15, 0, 0, 0);">

                <VBox spacing="5.0">
                    <Label text="ĐĂNG SẢN PHẨM"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #E5E5E5;"/>
                    <Label text="Nhập dữ liệu sản phẩm."
                           style="-fx-text-fill: #A0A0B0; -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Tên sản phẩm" style="-fx-text-fill: #E5E5E5; -fx-font-weight: bold;"/>
                    <TextField fx:id="nameField" promptText="Nhập tên vật phẩm..." prefHeight="45.0"
                               style="-fx-font-size: 15px; -fx-background-color: #242430; -fx-text-fill: white; -fx-border-color: #4A4A5A;"/>
                </VBox>

                <HBox spacing="20.0">
                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <Label text="Giá khởi điểm (VNĐ)"
                               style="-fx-text-fill: #E5E5E5; -fx-font-weight: bold;"/>
                        <TextField fx:id="priceField" promptText="VD: 50000" prefHeight="45.0"
                                   style="-fx-font-size: 15px; -fx-background-color: #242430; -fx-text-fill: white; -fx-border-color: #4A4A5A;"/>
                    </VBox>
                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <Label text="Bước nhảy giá tối thiểu *" style="-fx-text-fill: #E5E5E5; -fx-font-weight: bold;"/>
                        <TextField fx:id="stepField" promptText="VD: 1000" prefHeight="45.0"
                                   style="-fx-font-size: 15px; -fx-background-color: #242430; -fx-text-fill: white; -fx-border-color: #4A4A5A;"/>
                    </VBox>
                </HBox>

                <VBox spacing="8.0">
                    <Label text="Chi tiết dữ liệu (Mô tả) *" style="-fx-text-fill: #E5E5E5; -fx-font-weight: bold;"/>
                    <TextArea fx:id="descriptionArea" promptText="Nhập thông số kỹ thuật, nguồn gốc..."
                              prefHeight="160.0" wrapText="true"
                              style="-fx-font-size: 15px; -fx-control-inner-background: #242430; -fx-text-fill: white; -fx-border-color: #4A4A5A;"/>
                </VBox>

                <HBox spacing="15.0" alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0;">
                    <Button text="HỦY BỎ" onAction="#handleCancel" prefHeight="45.0" prefWidth="120.0"
                            style="-fx-background-color: transparent; -fx-text-fill: #A0A0B0; -fx-border-color: #A0A0B0; -fx-border-radius: 4; -fx-cursor: hand; -fx-font-weight: bold;"/>
                    <Button text="🚀 ĐỒNG BỘ (ĐĂNG BÁN)" onAction="#handleSaveProduct" prefHeight="45.0"
                            prefWidth="220.0"
                            style="-fx-background-color: linear-gradient(to right, #D8A95C, #F4D28A); -fx-text-fill: #12121A; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 4; -fx-font-size: 15px;"/>
                </HBox>

            </VBox>
        </HBox>
    </center>
</BorderPane>