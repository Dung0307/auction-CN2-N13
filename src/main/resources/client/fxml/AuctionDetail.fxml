                                    </image>
                                </ImageView>
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <Label text="Rolex Official Store"
                                           style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                                    <Label text="Uy tín: ⭐⭐⭐⭐⭐ (99% Tích cực)"
                                           style="-fx-text-fill: #f39c12; -fx-font-size: 13px;"/>
                                </VBox>
                                <Button text="Xem Shop"
                                        style="-fx-background-color: white; -fx-border-color: #ccc; -fx-border-radius: 4; -fx-cursor: hand; -fx-padding: 5 15;"/>
                            </HBox>

                            <VBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                                <Label text="Mô tả chi tiết"
                                       style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #111;"/>
                                <Label text="Mẫu đồng hồ Rolex GMT-Master II Ice mã tham chiếu 116769TBR là một kiệt tác thực sự. Toàn bộ lớp vỏ bằng vàng trắng 18k và mặt số đều được bao phủ bởi những viên kim cương lấp lánh tinh khiết nhất. Nó được trang bị bộ chuyển động tự lên dây cót caliber 3186, khả năng chống nước ở độ sâu 100 mét và vành bezel đính kim cương với thiết kế đặc trưng."
                                       wrapText="true"
                                       style="-fx-font-size: 14px; -fx-line-spacing: 6px; -fx-text-fill: #444;"/>
                            </VBox>

                        </VBox>
                    </HBox>

                    <Separator style="-fx-padding: 10 0;"/>

                    <HBox spacing="40.0" alignment="TOP_CENTER">

                        <VBox spacing="15.0" HBox.hgrow="ALWAYS" prefWidth="500.0"
                              style="-fx-background-color: #fafafa; -fx-padding: 20; -fx-border-color: #eee; -fx-border-radius: 8;">
                            <Label text="Lịch sử đấu giá" style="-fx-font-weight: bold; -fx-font-size: 18px;"/>
                            <VBox spacing="10.0">
                                <HBox spacing="10.0"
                                      style="-fx-border-color: #ccc; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 5 0;">
                                    <Label text="Người dùng" style="-fx-font-weight: bold;" prefWidth="120.0"/>
                                    <Label text="Mức giá" style="-fx-font-weight: bold;" prefWidth="150.0"/>
                                    <Label text="Thời gian" style="-fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
                                </HBox>
                                <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 5 0;">
                                    <Label text="nguoidung_01" prefWidth="120.0"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3f51b5;"/>
                                    <Label text="500.000.000 đ" prefWidth="150.0"
                                           style="-fx-text-fill: #d32f2f; -fx-font-weight: bold;"/>
                                    <Label text="Hôm nay, 10:30" HBox.hgrow="ALWAYS" style="-fx-text-fill: #777;"/>
                                </HBox>
                                <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 5 0;">
                                    <Label text="nguoidung_99" prefWidth="120.0" style="-fx-font-weight: bold;"/>
                                    <Label text="495.000.000 đ" prefWidth="150.0"/>
                                    <Label text="Hôm nay, 09:15" HBox.hgrow="ALWAYS" style="-fx-text-fill: #777;"/>
                                </HBox>
                                <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 5 0;">
                                    <Label text="vip_buyer" prefWidth="120.0" style="-fx-font-weight: bold;"/>
                                    <Label text="480.000.000 đ" prefWidth="150.0"/>
                                    <Label text="Hôm qua, 22:40" HBox.hgrow="ALWAYS" style="-fx-text-fill: #777;"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <VBox spacing="15.0" HBox.hgrow="ALWAYS" prefWidth="500.0"
                              style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #eee; -fx-border-radius: 8;">
                            <Label text="Biểu đồ biến động giá (30 ngày)"
                                   style="-fx-font-weight: bold; -fx-font-size: 18px;"/>
                            <LineChart fx:id="priceHistoryChart" prefHeight="250.0"
                                       style="-fx-padding: 0; -fx-opacity: 0.8;">
                                <xAxis>
                                    <CategoryAxis side="BOTTOM"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis side="LEFT"/>
                                </yAxis>
                            </LineChart>
                        </VBox>

                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>