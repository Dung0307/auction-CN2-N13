                                    <Label text="Mã SP: #081/088" style="-fx-text-fill: #555;"/>
                                </HBox>
                            </VBox>

                            <VBox spacing="15.0"
                                  style="-fx-background-color: #f4f6f8; -fx-padding: 25; -fx-background-radius: 12; -fx-border-color: #e0e0e0; -fx-border-radius: 12;">
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <Label text="Kết thúc sau:" style="-fx-text-fill: #555; -fx-font-size: 14px;"/>
