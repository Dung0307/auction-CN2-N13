                                       wrapText="true"
                                       style="-fx-font-size: 14px; -fx-line-spacing: 6px; -fx-text-fill: #A0A0B0;"/>
                            </VBox>

                        </VBox>
                    </HBox>

                    <Separator
                            style="-fx-padding: 10 0; -fx-background-color: transparent; -fx-border-color: #4A4A5A; -fx-border-width: 1 0 0 0;"/>

                    <HBox spacing="40.0" alignment="TOP_CENTER">

                        <VBox spacing="15.0" HBox.hgrow="ALWAYS" prefWidth="500.0"
