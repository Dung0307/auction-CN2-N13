                                           style="-fx-text-fill: #d32f2f; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                                </HBox>
                                <Separator style="-fx-background-color: #e0e0e0;"/>
                                <VBox spacing="5.0">
                                    <Label text="Giá đấu cao nhất hiện tại"
                                           style="-fx-text-fill: #777; -fx-font-size: 14px;"/>
                                    <HBox alignment="BOTTOM_LEFT" spacing="15.0">
                                        <Label text="500.000.000 VNĐ"
                                               style="-fx-text-fill: #3f51b5; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                                        <Label text="[12 lượt ra giá]"
                                               style="-fx-text-fill: #555; -fx-font-size: 14px; -fx-underline: true; -fx-cursor: hand;">
                                            <HBox.margin>
                                                <Insets bottom="6.0"/>
                                            </HBox.margin>
                                        </Label>
                                    </HBox>
                                </VBox>
                                <VBox spacing="10.0">
                                    <HBox spacing="10.0">
                                        <TextField fx:id="bidAmountField" promptText="VD: 510000000" prefHeight="55.0"
                                                   HBox.hgrow="ALWAYS"
                                                   style="-fx-font-size: 18px; -fx-background-radius: 6; -fx-border-color: #ccc; -fx-border-radius: 6;"/>
                                        <Button onAction="#placeBid" text="ĐẶT GIÁ NGAY" prefHeight="55.0"
                                                prefWidth="180.0"
                                                style="-fx-background-color: #111; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                                    </HBox>
                                    <Label text="* Giá đặt tiếp theo tối thiểu: 505.000.000 VNĐ"
                                           style="-fx-text-fill: #777; -fx-font-size: 12px;"/>
                                </VBox>
                            </VBox>

                            <HBox alignment="CENTER_LEFT" spacing="15.0"
                                  style="-fx-border-color: #eee; -fx-border-radius: 12; -fx-padding: 15;">
