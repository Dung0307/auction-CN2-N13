                                    <Label text="Mã định danh" style="-fx-font-weight: bold; -fx-text-fill: #777788;"
                                           prefWidth="120.0"/>
                                    <Label text="Mức Tín Dụng" style="-fx-font-weight: bold; -fx-text-fill: #777788;"
                                           prefWidth="150.0"/>
                                    <Label text="Dấu thời gian" style="-fx-font-weight: bold; -fx-text-fill: #777788;"
                                           HBox.hgrow="ALWAYS"/>
                                </HBox>
                                <HBox spacing="10.0" alignment="CENTER_LEFT"
                                      style="-fx-padding: 8 0; -fx-background-color: rgba(0, 229, 255, 0.05);">
                                    <Label text="nguoidung_01" prefWidth="120.0"
                                           style="-fx-font-weight: bold; -fx-text-fill: #00E5FF;"/>
                                    <Label text="500.000.000 đ" prefWidth="150.0"
                                           style="-fx-text-fill: #D8A95C; -fx-font-weight: bold;"/>
                                    <Label text="Hôm nay, 10:30" HBox.hgrow="ALWAYS" style="-fx-text-fill: #A0A0B0;"/>
                                </HBox>
                                <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 5 0;">
                                    <Label text="nguoidung_99" prefWidth="120.0"
                                           style="-fx-font-weight: bold; -fx-text-fill: #E5E5E5;"/>
                                    <Label text="495.000.000 đ" prefWidth="150.0" style="-fx-text-fill: #A0A0B0;"/>
                                    <Label text="Hôm nay, 09:15" HBox.hgrow="ALWAYS" style="-fx-text-fill: #777788;"/>
                                </HBox>
                                <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 5 0;">
                                    <Label text="vip_buyer" prefWidth="120.0"
                                           style="-fx-font-weight: bold; -fx-text-fill: #E5E5E5;"/>
                                    <Label text="480.000.000 đ" prefWidth="150.0" style="-fx-text-fill: #A0A0B0;"/>
                                    <Label text="Hôm qua, 22:40" HBox.hgrow="ALWAYS" style="-fx-text-fill: #777788;"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <VBox spacing="15.0" HBox.hgrow="ALWAYS" prefWidth="500.0"
                              style="-fx-background-color: rgba(26, 26, 36, 0.6); -fx-padding: 20; -fx-border-color: #4A4A5A; -fx-border-radius: 8;">
                            <Label text="BIỂU ĐỒ PHÂN TÍCH (30 CHU KỲ)"
                                   style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #D8A95C;"/>
                            <LineChart fx:id="priceHistoryChart" prefHeight="250.0"
                                       style="-fx-padding: 0; -fx-opacity: 0.9;">
                                <xAxis>
                                    <CategoryAxis side="BOTTOM" tickLabelFill="#A0A0B0"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis side="LEFT" tickLabelFill="#A0A0B0"/>
                                </yAxis>
                            </LineChart>
