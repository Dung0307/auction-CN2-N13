                                <Button text="🔗 Chia sẻ"
                                        style="-fx-background-color: white; -fx-border-color: #ccc; -fx-border-radius: 4; -fx-cursor: hand; -fx-text-fill: #333; -fx-font-weight: bold;"
                                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            </HBox>

                            <VBox spacing="12.0"
                                  style="-fx-background-color: #f8f9fa; -fx-padding: 18; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8;">
                                <Label text="🔒 Bảo đảm từ Auction Hub"
                                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #111;"/>

                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <Label text="✅" alignment="CENTER" prefWidth="25.0" style="-fx-font-size: 14px;"/>
                                    <VBox>
                                        <Label text="Kiểm định chính hãng 100%"
                                               style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
                                        <Label text="Hoàn tiền gấp đôi nếu phát hiện giả"
                                               style="-fx-text-fill: #777; -fx-font-size: 11px;"/>
                                    </VBox>
                                </HBox>

                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <Label text="📦" alignment="CENTER" prefWidth="25.0" style="-fx-font-size: 14px;"/>
                                    <VBox>
                                        <Label text="Vận chuyển bảo mật &amp; an toàn"
                                               style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
                                        <Label text="Được đóng gói và niêm phong chuyên dụng"
                                               style="-fx-text-fill: #777; -fx-font-size: 11px;"/>
                                    </VBox>
                                </HBox>

                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <Label text="🛡️" alignment="CENTER" prefWidth="25.0" style="-fx-font-size: 14px;"/>
                                    <VBox>
                                        <Label text="Bảo vệ người mua hàng"
                                               style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
                                        <Label text="Giữ tiền cho đến khi bạn xác nhận nhận hàng"
                                               style="-fx-text-fill: #777; -fx-font-size: 11px;"/>
                                    </VBox>
                                </HBox>
                            </VBox>
                        </VBox>

                        <VBox spacing="20.0" HBox.hgrow="ALWAYS" maxWidth="600.0">
