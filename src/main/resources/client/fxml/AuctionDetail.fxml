<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="850.0" prefWidth="1200.0" styleClass="main-background"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="auction.client.controller.AuctionDetailController">

    <top>
        <VBox>
            <fx:include source="NavBar.fxml"/>
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="breadcrumb-bar">
                <Button style="-fx-background-color: transparent; -fx-cursor: hand;" styleClass="text-gold"
                        text="&lt; QUAY LẠI CƠ SỞ DỮ LIỆU"/>
                <Separator orientation="VERTICAL" style="-fx-background-color: #4A4A5A;"/>
                <Label text="Trang chủ" styleClass="text-muted" style="-fx-cursor: hand;"/>
                <Label text="&gt;" style="-fx-text-fill: #4A4A5A;"/>
                <Label text="Đồng hồ cao cấp" styleClass="text-muted" style="-fx-cursor: hand;"/>
                <Label text="&gt;" style="-fx-text-fill: #4A4A5A;"/>
                <Label fx:id="breadcrumbLabel" text="Rolex GMT-Master II Ice" styleClass="text-bright"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: #12121A; -fx-border-color: transparent;">
            <content>
                <VBox spacing="40.0" style="-fx-padding: 30 50 50 50;" styleClass="main-background">

                    <HBox spacing="40.0" alignment="TOP_CENTER">

                        <VBox spacing="15.0" prefWidth="480.0">
                            <VBox alignment="CENTER" styleClass="image-frame">
                                <ImageView fx:id="productImage" fitHeight="476.0" fitWidth="476.0" pickOnBounds="true"
                                           preserveRatio="false" style="-fx-cursor: hand;">
                                    <image>
                                        <Image url="https://images.unsplash.com/photo-1523170335258-f5ed11844a49?auto=format&amp;fit=crop&amp;w=600&amp;q=80"/>
                                    </image>
                                </ImageView>
                            </VBox>

                            <HBox spacing="15.0" alignment="CENTER">
                                <Button text="★ THEO DÕI TÍN HIỆU" styleClass="btn-secondary" HBox.hgrow="ALWAYS"
                                        maxWidth="Infinity" prefHeight="40.0"/>
                                <Button text="🔗 TRÍCH XUẤT LIÊN KẾT" styleClass="btn-secondary" HBox.hgrow="ALWAYS"
                                        maxWidth="Infinity" prefHeight="40.0"/>
                            </HBox>

                            <VBox spacing="12.0" styleClass="guarantee-box">
                                <Label text="GIAO THỨC BẢO ĐẢM TỪ AUCTION HUB" styleClass="text-cyan"
                                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-letter-spacing: 1px;"/>

                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <Label text="[OK]" alignment="CENTER" prefWidth="30.0" styleClass="text-cyan"
                                           style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                    <VBox>
                                        <Label text="Kiểm định chuỗi khối 100%" styleClass="text-bright"/>
                                        <Label text="Hoàn trả gấp đôi tín dụng nếu phát hiện sai lệch dữ liệu"
                                               styleClass="text-muted" style="-fx-font-size: 11px;"/>
                                    </VBox>
                                </HBox>

                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <Label text="[BX]" alignment="CENTER" prefWidth="30.0" styleClass="text-cyan"
                                           style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                    <VBox>
                                        <Label text="Vận chuyển bảo mật cấp cao" styleClass="text-bright"/>
                                        <Label text="Đóng gói và niêm phong trong khoang chứa chuyên dụng"
                                               styleClass="text-muted" style="-fx-font-size: 11px;"/>
                                    </VBox>
                                </HBox>

                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <Label text="[SH]" alignment="CENTER" prefWidth="30.0" styleClass="text-cyan"
                                           style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                    <VBox>
                                        <Label text="Lá chắn bảo vệ giao dịch" styleClass="text-bright"/>
                                        <Label text="Đóng băng tín dụng cho đến khi xác nhận nhận hàng"
                                               styleClass="text-muted" style="-fx-font-size: 11px;"/>
                                    </VBox>
                                </HBox>
                            </VBox>
                        </VBox>

                        <VBox spacing="20.0" HBox.hgrow="ALWAYS" maxWidth="600.0">

                            <VBox spacing="8.0">
                                <Label fx:id="productTitle" text="Đồng hồ Rolex GMT-Master II Ice" wrapText="true"
                                       styleClass="text-bright" style="-fx-font-size: 28px;"/>
                                <HBox spacing="15.0" alignment="CENTER_LEFT">
                                    <Label fx:id="conditionLabel" text="Tình trạng: Mới nguyên (Mint)"
                                           styleClass="text-muted"/>
                                    <Separator orientation="VERTICAL" style="-fx-background-color: #4A4A5A;"/>
                                    <Label fx:id="productIdLabel" text="Mã SP: #081/088" styleClass="text-gold"
                                           style="-fx-font-family: monospace;"/>
                                </HBox>
                            </VBox>

                            <VBox spacing="15.0" styleClass="info-panel">
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <Label text="ĐÓNG CỔNG KẾT NỐI SAU:" styleClass="text-muted"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                                    <Label text="02 : 45 : 12" styleClass="text-danger"
                                           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                                </HBox>
                                <Separator style="-fx-background-color: #4A4A5A;"/>
                                <VBox spacing="5.0">
                                    <Label text="Mức tín dụng cao nhất hiện tại" styleClass="text-muted"
                                           style="-fx-font-size: 14px;"/>
                                    <HBox alignment="BOTTOM_LEFT" spacing="15.0">
                                        <Label fx:id="currentPriceLabel" text="500.000.000 VNĐ"
                                               styleClass="price-large"/>
                                        <Label text="[12 lượt ra giá]" styleClass="text-cyan"
                                               style="-fx-font-size: 14px; -fx-underline: true; -fx-cursor: hand;">
                                            <HBox.margin>
                                                <Insets bottom="6.0"/>
                                            </HBox.margin>
                                        </Label>
                                    </HBox>
                                </VBox>
                                <VBox spacing="10.0">
                                    <HBox spacing="10.0">
                                        <TextField fx:id="bidAmountField" promptText="VD: 510000000" prefHeight="55.0"
                                                   HBox.hgrow="ALWAYS" styleClass="dark-input-field"
                                                   style="-fx-font-size: 18px;"/>
                                        <Button onAction="#placeBid" text="🚀 ĐỒNG BỘ GIÁ" prefHeight="55.0"
                                                prefWidth="190.0" styleClass="btn-submit"/>
                                    </HBox>
                                    <Label fx:id="nextBidLabel"
                                           text="* Cảnh báo: Tín dụng tiếp theo tối thiểu phải đạt 505.000.000 VNĐ"
                                           style="-fx-text-fill: #777788; -fx-font-size: 12px;"/>
                                </VBox>
                            </VBox>

                            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="sub-panel"
                                  style="-fx-padding: 15px; -fx-background-color: rgba(26, 26, 36, 0.5);">
                                <ImageView fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="https://cdn-icons-png.flaticon.com/512/147/147144.png"/>
                                    </image>
                                </ImageView>
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <Label fx:id="storeNameLabel" text="Rolex Official Hub" styleClass="text-bright"
                                           style="-fx-font-size: 16px;"/>
                                    <Label text="Độ tin cậy: Cấp S (99% Phản hồi tích cực)" styleClass="text-cyan"
                                           style="-fx-font-size: 13px;"/>
                                </VBox>
                                <Button text="TRUY CẬP HUB"
                                        style="-fx-background-color: transparent; -fx-border-color: #D8A95C; -fx-text-fill: #D8A95C; -fx-border-radius: 4; -fx-cursor: hand; -fx-padding: 8 15; -fx-font-weight: bold;"/>
                            </HBox>

                            <VBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                                <Label text="DỮ LIỆU LƯU TRỮ (MÔ TẢ)" styleClass="text-gold"
                                       style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-letter-spacing: 1px;"/>
                                <Label fx:id="descriptionLabel" text="Mẫu đồng hồ Rolex..." wrapText="true"
                                       styleClass="text-muted" style="-fx-font-size: 14px; -fx-line-spacing: 6px;"/>
                            </VBox>

                        </VBox>
                    </HBox>

                    <Separator
                            style="-fx-padding: 10 0; -fx-background-color: transparent; -fx-border-color: #4A4A5A; -fx-border-width: 1 0 0 0;"/>

                    <HBox spacing="40.0" alignment="TOP_CENTER">

                        <VBox spacing="15.0" HBox.hgrow="ALWAYS" prefWidth="500.0" styleClass="sub-panel">
                            <Label text="NHẬT KÝ ĐỒNG BỘ GIÁ" styleClass="text-gold"
                                   style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                            <VBox spacing="10.0">
                                <HBox spacing="10.0"
                                      style="-fx-border-color: #4A4A5A; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 5 0;">
                                    <Label text="Mã định danh" style="-fx-font-weight: bold; -fx-text-fill: #777788;"
                                           prefWidth="120.0"/>
                                    <Label text="Mức Tín Dụng" style="-fx-font-weight: bold; -fx-text-fill: #777788;"
                                           prefWidth="150.0"/>
                                    <Label text="Dấu thời gian" style="-fx-font-weight: bold; -fx-text-fill: #777788;"
                                           HBox.hgrow="ALWAYS"/>
                                </HBox>
                                <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="history-row-active"
                                      style="-fx-padding: 8 0;">
                                    <Label text="nguoidung_01" prefWidth="120.0" styleClass="text-cyan"
                                           style="-fx-font-weight: bold;"/>
                                    <Label text="500.000.000 đ" prefWidth="150.0" styleClass="text-gold"
                                           style="-fx-font-weight: bold;"/>
                                    <Label text="Hôm nay, 10:30" HBox.hgrow="ALWAYS" styleClass="text-muted"/>
                                </HBox>
                                <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 5 0;">
                                    <Label text="nguoidung_99" prefWidth="120.0" styleClass="text-bright"/>
                                    <Label text="495.000.000 đ" prefWidth="150.0" styleClass="text-muted"/>
                                    <Label text="Hôm nay, 09:15" HBox.hgrow="ALWAYS" style="-fx-text-fill: #777788;"/>
                                </HBox>
                                <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 5 0;">
                                    <Label text="vip_buyer" prefWidth="120.0" styleClass="text-bright"/>
                                    <Label text="480.000.000 đ" prefWidth="150.0" styleClass="text-muted"/>
                                    <Label text="Hôm qua, 22:40" HBox.hgrow="ALWAYS" style="-fx-text-fill: #777788;"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <VBox spacing="15.0" HBox.hgrow="ALWAYS" prefWidth="500.0" styleClass="sub-panel">
                            <Label text="BIỂU ĐỒ PHÂN TÍCH (30 CHU KỲ)" styleClass="text-gold"
                                   style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                            <LineChart fx:id="priceHistoryChart" prefHeight="250.0"
                                       style="-fx-padding: 0; -fx-opacity: 0.9;">
                                <xAxis>
                                    <CategoryAxis side="BOTTOM" tickLabelFill="#A0A0B0"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis side="LEFT" tickLabelFill="#A0A0B0"/>
                                </yAxis>
                            </LineChart>
                        </VBox>

                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>