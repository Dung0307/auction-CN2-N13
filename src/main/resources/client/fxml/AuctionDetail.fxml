                                    <image>
                                        <Image url="https://cdn-icons-png.flaticon.com/512/147/147144.png"/>
                                    </image>
                                </ImageView>
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <Label fx:id="storeNameLabel" text="Rolex Official Hub"
                                           style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #E5E5E5;"/>
                                    <Label text="Độ tin cậy: Cấp S (99% Phản hồi tích cực)"
                                           style="-fx-text-fill: #00E5FF; -fx-font-size: 13px;"/>
