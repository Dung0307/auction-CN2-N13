                                                style="-fx-background-color: linear-gradient(to right, #D8A95C, #F4D28A); -fx-text-fill: #12121A; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 4; -fx-cursor: hand;"/>
                                    </HBox>
                                    <Label fx:id="nextBidLabel"
                                           text="* Cảnh báo: Tín dụng tiếp theo tối thiểu phải đạt 505.000.000 VNĐ"
                                           style="-fx-text-fill: #777788; -fx-font-size: 12px;"/>
                                </VBox>
                            </VBox>

                            <HBox alignment="CENTER_LEFT" spacing="15.0"
                                  style="-fx-border-color: #4A4A5A; -fx-border-radius: 8; -fx-padding: 15; -fx-background-color: rgba(26, 26, 36, 0.5);">
