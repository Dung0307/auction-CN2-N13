                                                   style="-fx-font-size: 18px; -fx-background-color: #0B0B10; -fx-text-fill: #E5E5E5; -fx-background-radius: 4; -fx-border-color: #D8A95C; -fx-border-radius: 4;"/>
                                        <Button onAction="#placeBid" text="🚀 ĐỒNG BỘ GIÁ" prefHeight="55.0"
