<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="850.0" prefWidth="1200.0" style="-fx-background-color: #12121A;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="auction.client.controller.AuctionDetailController">

    <top>
        <VBox>
            <fx:include source="NavBar.fxml"/>
            <HBox alignment="CENTER_LEFT" spacing="10.0"
                  style="-fx-background-color: rgba(26, 26, 36, 0.9); -fx-padding: 12 30; -fx-border-color: #4A4A5A; -fx-border-width: 0 0 1 0;">
